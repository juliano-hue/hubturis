# Banco de Dados
DATABASE_URL="postgresql://usuario:senha@localhost:5432/turishubdb"

# URL da Aplicação
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Ambiente
NODE_ENV="development"

# Rate Limiting
API_RATE_LIMIT=1000
API_RATE_WINDOW=60000

# Logs
LOG_LEVEL="debug"
LOG_TO_FILE=false
LOG_DIR="./logs"

# Email
SMTP_HOST="smtp.ethereal.email"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""

# Pagamento
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""