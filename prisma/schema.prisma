generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(uuid())
  name            String?
  email           String           @unique
  password        String
  role            UserRole         @default(CONSUMER)
  emailVerified   DateTime?
  image           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  attractions     Attraction[]
  bookings        Booking[]
  carts           Cart[]
  consumerProfile ConsumerProfile?
  favorites       Favorite[]
  providerProfile ProviderProfile?
  reviews         Review[]
  accessLogs      AccessLog[]

  @@map("users")
}

model ProviderProfile {
  id            String      @id @default(uuid())
  userId        String      @unique
  fullName      String
  cpf           String      @unique
  phone         String
  address       String
  city          String
  state         String      @db.VarChar(2)
  zipCode       String
  bankName      String
  agency        String
  accountNumber String
  accountType   AccountType
  pixKey        String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("provider_profiles")
}

model ConsumerProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  fullName    String
  cpf         String   @unique
  phone       String
  address     String
  city        String
  state       String   @db.VarChar(2)
  paymentType String
  cardNumber  String?
  cardExpiry  String?
  cardCvv     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  cardBrand   String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("consumer_profiles")
}

model Attraction {
  id             String         @id @default(uuid())
  title          String
  description    String
  location       String
  city           String
  state          String         @db.VarChar(2)
  price          Float
  duration       Int?
  maxCapacity    Int?
  category       String?
  providerId     String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  images         String[]
  pricingType    String         @default("PER_PERSON")
  provider       User           @relation(fields: [providerId], references: [id], onDelete: Cascade)
  availabilities Availability[]
  bookings       Booking[]
  carts          Cart[]
  favorites      Favorite[]
  reviews        Review[]

  @@index([providerId])
  @@index([city, state])
  @@map("attractions")
}

model Availability {
  id              String     @id @default(uuid())
  attractionId    String
  date            DateTime
  price           Float?
  maxParticipants Int        @default(10)
  isAvailable     Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  attraction      Attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade)
  bookings        Booking[]
  carts           Cart[]

  @@index([attractionId])
  @@index([date])
  @@map("availabilities")
}

model Booking {
  id              String        @id @default(uuid())
  consumerId      String
  attractionId    String
  availabilityId  String?
  date            DateTime
  participants    Int
  totalPrice      Float
  status          BookingStatus @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  specialRequests String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  attraction      Attraction    @relation(fields: [attractionId], references: [id], onDelete: Cascade)
  availability    Availability? @relation(fields: [availabilityId], references: [id])
  consumer        User          @relation(fields: [consumerId], references: [id], onDelete: Cascade)

  @@index([consumerId])
  @@index([attractionId])
  @@index([status])
  @@index([date])
  @@map("bookings")
}

model Review {
  id           String     @id @default(uuid())
  rating       Int
  comment      String?
  consumerId   String
  attractionId String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  attraction   Attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade)
  consumer     User       @relation(fields: [consumerId], references: [id], onDelete: Cascade)

  @@unique([consumerId, attractionId])
  @@index([attractionId])
  @@index([consumerId])
  @@map("reviews")
}

model Cart {
  id              String        @id @default(uuid())
  consumerId      String
  attractionId    String
  availabilityId  String?
  date            DateTime
  participants    Int
  price           Float
  totalPrice      Float
  specialRequests String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  attraction      Attraction    @relation(fields: [attractionId], references: [id], onDelete: Cascade)
  availability    Availability? @relation(fields: [availabilityId], references: [id])
  consumer        User          @relation(fields: [consumerId], references: [id], onDelete: Cascade)

  @@unique([consumerId, attractionId, availabilityId, date])
  @@index([consumerId])
  @@map("carts")
}

model Favorite {
  id           String     @id @default(uuid())
  consumerId   String
  attractionId String
  createdAt    DateTime   @default(now())
  attraction   Attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade)
  consumer     User       @relation(fields: [consumerId], references: [id], onDelete: Cascade)

  @@unique([consumerId, attractionId])
  @@index([consumerId])
  @@map("favorites")
}

model AccessLog {
  id        String   @id @default(uuid())
  userId    String
  userEmail String
  userRole  String
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("access_logs")
}

enum UserRole {
  CONSUMER
  PROVIDER
  ADMIN
}

enum AccountType {
  CORRENTE
  POUPANCA
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}